{
  "manifest_version": 3,
  "name": "DSA Revision Tracker",
  "version": "1.0.0",
  "description": "Track your DSA revisions from LeetCode, Codeforces, CSES, and GeeksforGeeks.",

  "permissions": [
    "storage",
    "identity",
    "activeTab",
    "scripting",
    "alarms"
  ],

  "host_permissions": [
    "*://leetcode.com/*",
    "*://codeforces.com/*",
    "*://cses.fi/*",
    "*://www.geeksforgeeks.org/*",
    "*://practice.geeksforgeeks.org/*",
    "http://localhost:5175/*",
    "http://localhost:5000/*"
  ],

  "background": {
    "service_worker": "serviceWorker.js",
    "type": "module"
  },

  "icons": {
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Save for Revision",
    "default_icon": {
        "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "*://leetcode.com/problems/*",
        "*://codeforces.com/problemset/problem/*",
        "*://codeforces.com/contest/*/problem/*",
        "*://codeforces.com/gym/*/problem/*",
        "*://cses.fi/problemset/task/*",
        "*://www.geeksforgeeks.org/problems/*",
        "*://practice.geeksforgeeks.org/problems/*"
      ],
      "js": ["contentScript.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["authSuccess.html", "authSuccess.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "externally_connectable": {
    "matches": ["http://localhost:5000/*"]
  },
  "key" : ""
}
